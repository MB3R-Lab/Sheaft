{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MB3R-Lab/Sheaft/api/schema/journeys.schema.json",
  "title": "SheaftJourneyOverrides",
  "type": "object",
  "required": [
    "schema_version",
    "journeys"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "journeys": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
